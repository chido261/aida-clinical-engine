  "clinicalProtocols": {
    "hypoglycemia_15_15": {
      "name": "Protocolo 15-15",
      "trigger": "glucose_below_70",
      "steps": [
        "Tomar 15 g de carbohidrato de absorcion rapida.",
        "Esperar 15 minutos.",
        "Volver a medir glucosa.",
        "Si sigue debajo de 70, repetir una vez.",
        "Si hay sintomas graves o no mejora, buscar atencion medica urgente."
      ],
      "followUpRequired": true
    },
    "postmeal_plate_review": {
      "name": "Revision de plato postcomida",
      "trigger": "postmeal_glucose_above_140",
      "steps": [
        "Confirmar tiempo desde la comida.",
        "Pedir descripcion del plato.",
        "Identificar alimentos que pudieron elevar glucosa.",
        "Reconocer elementos adecuados del plato.",
        "Sugerir ajuste concreto para la siguiente comida."
      ],
      "followUpRequired": true
    }
  }
