generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model UserState {
  id        String   @id // deviceId (NO default demo-user)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // onboarding persistente
  name              String?
  age               Int?
  heightCm          Float?
  weightKg          Float?
  diagnosis         String?
  meds              String?
  fastingPeakMgDl   Int?
  postMealPeakMgDl  Int?
  wakeTime          String?
  onboardingDoneAt  DateTime?

  // baseline
  baselineA1c        Float?
  baselineAvgGlucose Int?
  baselineSetAt      DateTime?

  // protocolo / fase actual
  activeProtocol           String  @default("PROTOCOL_1")
  activePhase              String  @default("FASE_1")
  protocolStartedAt        DateTime?
  eligibleForNextProtocol  Boolean @default(false)
  protocolReviewReason     String?

  // rate limit / uso diario
  dailyMsgDate  String?
  dailyMsgCount Int?

  // métricas simples
  totalMsgCount Int      @default(0)
  lastMsgAt     DateTime?

  // trial
  trialStartedAt DateTime?
  trialEndsAt    DateTime?
  licenseStatus  String   @default("trial") // trial | active | maintenance | expired

  // full / licencia activa
  fullStartedAt     DateTime?
  fullEndsAt        DateTime?
  activePlan        String?
  activePlanSource  String?

  // OTP / licencia
  phoneE164       String?
  phoneVerifiedAt DateTime?

  // estado clínico persistente
  clinicalState String? 
  // STABLE | HYPO_ACTIVE | RECOVERING_FROM_HYPO | POSTMEAL_ELEVATED | POSTMEAL_RECOVERY | null

  // seguimiento conversacional persistente
  lastEventType       String?
  lastEventAt         DateTime?
  pendingFollowUpType String?
  pendingFollowUpAt   DateTime?
  lastRecommendation  String?

  // objetivo actual del asesor
  currentNutritionGoal String?
  // LOWER_GLUCOSE | MAINTAIN_GLUCOSE | RAISE_GLUCOSE | STABILIZE | REVIEW_MEAL | NONE

  // resumen diario
  dailySummaryDate  String?
  dailySummaryCount Int?

  @@index([phoneE164])
  @@index([licenseStatus])
  @@index([onboardingDoneAt])
  @@index([activeProtocol])
  @@index([activePhase])
  @@index([clinicalState])
  @@index([pendingFollowUpType])
}

model Reading {
  id        Int      @id @default(autoincrement())
  userId    String
  glucose   Int
  moment    String
  // AYUNO | ANTES_COMER | POSTCOMIDA | NOCHE | RECUPERACION_HIPO | POSTMEAL_RECOVERY | DESCONOCIDO

  symptoms  String?
  createdAt DateTime @default(now())

  // contexto clínico
  eventType      String?
  nutritionGoal  String?
  relatedMealId  Int?

  @@index([userId])
  @@index([createdAt])
  @@index([moment])
  @@index([eventType])
  @@index([nutritionGoal])
}

model ClinicalEvent {
  id        Int      @id @default(autoincrement())
  userId    String
  type      String
  // HYPOGLYCEMIA | HYPOGLYCEMIA_RESOLVED | POSTMEAL_ELEVATED | POSTMEAL_WALK_RECHECK | POSTMEAL_WALK_RESOLVED | STABLE_READING

  status    String   @default("OPEN")
  // OPEN | RESOLVED | CANCELLED

  openedAt  DateTime @default(now())
  closedAt  DateTime?

  glucoseAtOpen   Int?
  glucoseAtClose  Int?
  moment          String?
  nutritionGoal   String?

  pendingFollowUpType String?
  lastRecommendation  String?
  resolutionNote       String?

  @@index([userId])
  @@index([type])
  @@index([status])
  @@index([openedAt])
}

model MealLog {
  id        Int      @id @default(autoincrement())
  userId    String
  createdAt DateTime @default(now())

  mealMoment String?
  // DESAYUNO | COMIDA | CENA | SNACK | DESCONOCIDO

  rawText String

  detectedFoods          String?
  protocolAllowedFoods   String?
  protocolExcludedFoods  String?

  activeProtocol String @default("PROTOCOL_1")
  activePhase    String @default("FASE_1")

  protocolCompliant Boolean?
  nutritionGoal     String?
  relatedReadingId  Int?

  advisorNote String?

  @@index([userId])
  @@index([createdAt])
  @@index([activeProtocol])
  @@index([protocolCompliant])
  @@index([nutritionGoal])
}

model ProtocolProgress {
  id        Int      @id @default(autoincrement())
  userId    String
  protocol  String
  phase     String

  startedAt DateTime @default(now())
  endedAt   DateTime?

  status String @default("ACTIVE")
  // ACTIVE | COMPLETED | PAUSED | REGRESSED

  stableDaysCount       Int     @default(0)
  postMealInRangeCount  Int     @default(0)
  fastingInRangeCount   Int     @default(0)
  hypoEventsCount       Int     @default(0)
  highEventsCount       Int     @default(0)

  eligibleForNextProtocol Boolean @default(false)
  reviewReason            String?

  @@index([userId])
  @@index([protocol])
  @@index([phase])
  @@index([status])
}

model UsageDaily {
  id            Int      @id @default(autoincrement())
  userId        String
  dateLocal     String
  count         Int      @default(0)
  licenseStatus String
  updatedAt     DateTime @updatedAt

  @@unique([userId, dateLocal])
  @@index([userId])
}

model ActivationRequest {
  id        Int      @id @default(autoincrement())
  deviceId  String
  name      String
  phone     String
  plan      String
  price     Int
  duration  Int
  status    String   @default("pending")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([deviceId])
  @@index([phone])
  @@index([status])
}

model Payment {
  id                Int       @id @default(autoincrement())
  provider          String
  providerPaymentId String?
  providerRef       String?
  status            String    @default("created")
  amount            Int
  currency          String    @default("MXN")
  plan              String
  durationDays      Int
  phoneE164         String
  deviceId          String?
  activationCodeId  Int?

  rawPayload        String?

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  approvedAt        DateTime?

  @@index([provider])
  @@index([providerPaymentId])
  @@index([providerRef])
  @@index([status])
  @@index([phoneE164])
  @@index([activationCodeId])
}

model ActivationCode {
  id              Int       @id @default(autoincrement())
  code            String    @unique
  phoneE164       String
  plan            String
  status          String    @default("active")
  currentDeviceId String?
  createdBy       String    @default("payment")
  lastPaymentId   Int?

  fullStartedAt   DateTime?
  fullEndsAt      DateTime?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  activatedAt     DateTime?

  @@index([phoneE164])
  @@index([status])
  @@index([currentDeviceId])
  @@index([lastPaymentId])
}

model DeviceSession {
  id               Int       @id @default(autoincrement())
  phoneE164        String
  deviceId         String
  activationCodeId Int
  active           Boolean   @default(true)
  createdAt        DateTime  @default(now())
  disabledAt       DateTime?

  @@index([phoneE164])
  @@index([deviceId])
  @@index([activationCodeId])
  @@index([active])
}