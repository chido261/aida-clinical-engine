generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model UserState {
  id        String   @id // deviceId (NO default demo-user)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // baseline
  baselineA1c        Float?
  baselineAvgGlucose Int?
  baselineSetAt      DateTime?

  // rate limit / uso diario (lo usaremos con FECHA LOCAL MX)
  dailyMsgDate  String?
  dailyMsgCount Int?

  // métricas simples
  totalMsgCount Int      @default(0)
  lastMsgAt     DateTime?

  // trial
  trialStartedAt DateTime?
  trialEndsAt    DateTime?
  licenseStatus  String   @default("trial") // trial | active | expired

  // full / licencia activa
  fullStartedAt DateTime?
  fullEndsAt    DateTime?
  activePlan       String? // mensual | 3-meses | anual | manual
  activePlanSource String? // activation-request | manual-extension | promo | admin

  // OTP / licencia (siguiente sprint)
  phoneE164       String?  // +52...
  phoneVerifiedAt DateTime?

  // estado clínico persistente (motor conversacional)
  clinicalState String? // HYPO_ACTIVE | RECOVERING_FROM_HYPO | null

  // seguimiento conversacional persistente
  lastEventType       String?
  lastEventAt         DateTime?
  pendingFollowUpType String?
  pendingFollowUpAt   DateTime?
  lastRecommendation  String?

  // resumen diario (1 vez por día)
  dailySummaryDate  String?
  dailySummaryCount Int?
}

model Reading {
  id        Int      @id @default(autoincrement())
  userId    String
  glucose   Int
  moment    String
  symptoms  String?
  createdAt DateTime @default(now())
}

model UsageDaily {
  id            Int      @id @default(autoincrement())
  userId        String
  dateLocal     String   // YYYY-MM-DD (America/Mexico_City)
  count         Int      @default(0)
  licenseStatus String   // trial | active
  updatedAt     DateTime @updatedAt

  @@unique([userId, dateLocal])
}

model ActivationRequest {
  id        Int      @id @default(autoincrement())
  deviceId  String
  name      String
  phone     String
  plan      String   // mensual | 3-meses | anual
  price     Int      // 500 | 1500 | 3000
  duration  Int      // días: 30 | 90 | 365
  status    String   @default("pending") // pending | paid | activated | cancelled

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([deviceId])
  @@index([phone])
  @@index([status])
}