generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model UserState {
  id        String   @id // deviceId (NO default demo-user)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // onboarding persistente
  name              String?
  age               Int?
  heightCm          Float?
  weightKg          Float?
  diagnosis         String?
  meds              String?
  fastingPeakMgDl   Int?
  postMealPeakMgDl  Int?
  wakeTime          String?
  onboardingDoneAt  DateTime?

  // baseline
  baselineA1c        Float?
  baselineAvgGlucose Int?
  baselineSetAt      DateTime?

  // rate limit / uso diario (lo usaremos con FECHA LOCAL MX)
  dailyMsgDate  String?
  dailyMsgCount Int?

  // métricas simples
  totalMsgCount Int      @default(0)
  lastMsgAt     DateTime?

  // trial
  trialStartedAt DateTime?
  trialEndsAt    DateTime?
  licenseStatus  String   @default("trial") // trial | active | maintenance | expired

  // full / licencia activa
  fullStartedAt DateTime?
  fullEndsAt    DateTime?
  activePlan       String? // mensual | 3-meses | anual | manual
  activePlanSource String? // payment | activation-code | activation-request | manual-extension | promo | admin

  // OTP / licencia
  phoneE164       String?  // +52...
  phoneVerifiedAt DateTime?

  // estado clínico persistente (motor conversacional)
  clinicalState String? // HYPO_ACTIVE | RECOVERING_FROM_HYPO | null

  // seguimiento conversacional persistente
  lastEventType       String?
  lastEventAt         DateTime?
  pendingFollowUpType String?
  pendingFollowUpAt   DateTime?
  lastRecommendation  String?

  // resumen diario (1 vez por día)
  dailySummaryDate  String?
  dailySummaryCount Int?

  @@index([phoneE164])
  @@index([licenseStatus])
  @@index([onboardingDoneAt])
}

model Reading {
  id        Int      @id @default(autoincrement())
  userId    String
  glucose   Int
  moment    String
  symptoms  String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

model UsageDaily {
  id            Int      @id @default(autoincrement())
  userId        String
  dateLocal     String   // YYYY-MM-DD (America/Mexico_City)
  count         Int      @default(0)
  licenseStatus String   // trial | active | maintenance | expired
  updatedAt     DateTime @updatedAt

  @@unique([userId, dateLocal])
  @@index([userId])
}

model ActivationRequest {
  id        Int      @id @default(autoincrement())
  deviceId  String
  name      String
  phone     String
  plan      String   // mensual | 3-meses | anual
  price     Int      // 500 | 1500 | 3000
  duration  Int      // días: 30 | 90 | 365
  status    String   @default("pending") // pending | paid | activated | cancelled

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([deviceId])
  @@index([phone])
  @@index([status])
}

model Payment {
  id                Int       @id @default(autoincrement())
  provider          String    // mercadopago
  providerPaymentId String?
  providerRef       String?   // preferenceId, externalReference u otro identificador
  status            String    @default("created") // created | pending | approved | rejected | cancelled | refunded
  amount            Int
  currency          String    @default("MXN")
  plan              String    // mensual | 3-meses | anual
  durationDays      Int
  phoneE164         String
  deviceId          String?
  activationCodeId  Int?

  rawPayload        String?

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  approvedAt        DateTime?

  @@index([provider])
  @@index([providerPaymentId])
  @@index([providerRef])
  @@index([status])
  @@index([phoneE164])
  @@index([activationCodeId])
}

model ActivationCode {
  id              Int       @id @default(autoincrement())
  code            String    @unique
  phoneE164       String
  plan            String    // mensual | 3-meses | anual
  status          String    @default("active") // active | expired | cancelled
  currentDeviceId String?
  createdBy       String    @default("payment") // payment | admin | manual
  lastPaymentId   Int?

  fullStartedAt   DateTime?
  fullEndsAt      DateTime?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  activatedAt     DateTime?

  @@index([phoneE164])
  @@index([status])
  @@index([currentDeviceId])
  @@index([lastPaymentId])
}

model DeviceSession {
  id               Int       @id @default(autoincrement())
  phoneE164        String
  deviceId         String
  activationCodeId Int
  active           Boolean   @default(true)
  createdAt        DateTime  @default(now())
  disabledAt       DateTime?

  @@index([phoneE164])
  @@index([deviceId])
  @@index([activationCodeId])
  @@index([active])
}